rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Primary admin email bypass for setup
      let isPrimaryAdmin = request.auth.token.email == "fosa.academyy@gmail.com" || 
                           request.auth.token.email == "karam.3bedat@gmail.com";
      // Document-based admin check
      let hasAdminDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      return isSignedIn() && (isPrimaryAdmin || hasAdminDoc);
    }

    function isCoach() {
      // Coaches are either those with coach role in users or those with established trainer IDs
      let hasCoachDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach';
      return isSignedIn() && (hasCoachDoc || exists(/databases/$(database)/documents/trainers/$(request.auth.uid)));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow update: if isSignedIn() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isCoach();
      allow delete: if isAdmin();
    }

    match /trainers/{trainerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(trainerId);
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isCoach();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isCoach();
      allow delete: if isAdmin();
    }

    match /coach_attendance/{attendanceId} {
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.coach_id == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.coach_id == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.coach_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /student_evaluations/{evalId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isCoach();
    }

    match /student_media/{mediaId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isCoach();
    }

    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isCoach();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read, list: if isAdmin();
      allow create: if isAdmin() || isCoach();
      allow update, delete: if isAdmin();
    }

    match /insights/{insightId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
