{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "role": { "type": "string", "enum": ["admin", "coach"], "description": "User role" },
        "displayName": { "type": "string", "description": "User display name" }
      },
      "required": ["uid", "email", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student information",
      "type": "object",
      "properties": {
        "full_name": { "type": "string" },
        "parent_name": { "type": "string" },
        "phone": { "type": "string" },
        "age": { "type": "number" },
        "level": { "type": "string" },
        "medical_notes": { "type": "string" },
        "registration_date": { "type": "string" },
        "current_points": { "type": "number" },
        "lifetime_points": { "type": "number" },
        "loyalty_tier": { "type": "string", "enum": ["برونزي", "فضي", "ذهبي"] },
        "assigned_coach_id": { "type": "string" },
        "course_id": { "type": "string", "description": "Linked course cycle ID" },
        "subscription_model": { "type": "string", "enum": ["monthly", "credit", "rolling"] },
        "remaining_sessions": { "type": "number" },
        "subscription_start_date": { "type": "string" },
        "subscription_end_date": { "type": "string" },
        "first_session_date": { "type": "string" }
      },
      "required": ["full_name", "phone"]
    },
    "CourseCycle": {
      "title": "CourseCycle",
      "description": "Training cycle with dates",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "course_type": { "type": "string" },
        "start_date": { "type": "string" },
        "end_date": { "type": "string" },
        "estimated_cost": { "type": "number" },
        "status": { "type": "string", "enum": ["نشط", "مكتمل", "قادم"] },
        "coach_id": { "type": "string" }
      },
      "required": ["name", "course_type", "start_date", "end_date", "estimated_cost"]
    },
    "StudentEvaluation": {
      "title": "StudentEvaluation",
      "description": "Coach assessment of student",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "coach_id": { "type": "string" },
        "coach_name": { "type": "string" },
        "date": { "type": "string" },
        "skills": {
          "type": "object",
          "properties": {
            "swimming": { "type": "number" },
            "stamina": { "type": "number" },
            "technique": { "type": "number" },
            "behavior": { "type": "number" }
          }
        },
        "comments": { "type": "string" }
      }
    },
    "StudentMedia": {
      "title": "StudentMedia",
      "description": "Photos and videos for students",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "coach_id": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video"] },
        "description": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "Coach": {
      "title": "Coach",
      "description": "Coach information",
      "type": "object",
      "properties": {
        "full_name": { "type": "string" },
        "specialization": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "loyalty_points": { "type": "number" }
      },
      "required": ["full_name"]
    },
    "CoachAttendance": {
      "title": "CoachAttendance",
      "description": "Coach check-in/out records",
      "type": "object",
      "properties": {
        "coach_id": { "type": "string" },
        "coach_name": { "type": "string" },
        "date": { "type": "string" },
        "check_in": { "type": "string" },
        "check_out": { "type": "string" },
        "duration_minutes": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["coach_id", "date", "check_in"]
    },
    "Session": {
      "title": "Session",
      "description": "Training session",
      "type": "object",
      "properties": {
        "day": { "type": "string" },
        "start_time": { "type": "string" },
        "end_time": { "type": "string" },
        "coach_name": { "type": "string" },
        "max_capacity": { "type": "number" },
        "required_level": { "type": "string" }
      },
      "required": ["day", "start_time", "end_time"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Student booking in a session",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "student_name": { "type": "string" },
        "session_id": { "type": "string" },
        "session_day": { "type": "string" },
        "session_time": { "type": "string" },
        "coach_name": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["student_id", "session_id", "date"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Legacy payment record",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "student_name": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["student_id", "amount", "date"]
    },
    "Product": {
      "title": "Product",
      "description": "Product for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "stock"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Unified financial transaction",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "student_name": { "type": "string" },
        "total_amount": { "type": "number" },
        "date": { "type": "string" },
        "method": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        }
      },
      "required": ["student_id", "total_amount", "date", "method", "items"]
    },
    "AcademyConfig": {
      "title": "AcademyConfig",
      "description": "Global academy settings",
      "type": "object",
      "properties": {
        "academyName": { "type": "string" },
        "academyPhone": { "type": "string" },
        "bitPhone": { "type": "string" },
        "payboxPhone": { "type": "string" },
        "bankName": { "type": "string" },
        "bankAccount": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/students/{id}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/trainers/{id}": {
      "schema": "Coach",
      "description": "Coach records"
    },
    "/sessions/{id}": {
      "schema": "Session",
      "description": "Training sessions"
    },
    "/bookings/{id}": {
      "schema": "Booking",
      "description": "Session bookings"
    },
    "/payments/{id}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/student_evaluations/{id}": {
      "schema": "StudentEvaluation",
      "description": "Student evaluation records"
    },
    "/student_media/{id}": {
      "schema": "StudentMedia",
      "description": "Student media records"
    },
    "/coach_attendance/{id}": {
      "schema": "CoachAttendance",
      "description": "Coach attendance records"
    },
    "/courses/{id}": {
      "schema": "CourseCycle",
      "description": "Course cycle records"
    },
    "/settings/app_config": {
      "schema": "AcademyConfig",
      "description": "Global academy settings"
    },
    "/products/{id}": {
      "schema": "Product",
      "description": "Product catalog and stock"
    },
    "/transactions/{id}": {
      "schema": "Transaction",
      "description": "Unified transaction records"
    }
  }
}
